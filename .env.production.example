# ── PostgreSQL (shared) ───────────────────────────────────────────────────────
POSTGRES_USER=cooldown
POSTGRES_PASSWORD=          # Generate: openssl rand -base64 32

# ── Strapi ────────────────────────────────────────────────────────────────────
STRAPI_URL=                # Public CMS URL, e.g. https://cms.example.com
SITE_URL=                  # Public web URL, e.g. https://example.com
APP_KEYS=                   # Generate: openssl rand -base64 32,openssl rand -base64 32
API_TOKEN_SALT=             # Generate: openssl rand -base64 32
ADMIN_JWT_SECRET=           # Generate: openssl rand -base64 32
TRANSFER_TOKEN_SALT=        # Generate: openssl rand -base64 32
JWT_SECRET=                 # Generate: openssl rand -base64 32
ENCRYPTION_KEY=             # Generate: openssl rand -base64 32

# ── Umami ─────────────────────────────────────────────────────────────────────
UMAMI_APP_SECRET=           # Generate: openssl rand -base64 32
